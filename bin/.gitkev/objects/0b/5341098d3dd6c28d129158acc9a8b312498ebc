package commands;
import java.io.IOException;
import java.nio.file.*;
import java.nio.file.attribute.BasicFileAttributes;
import java.util.ArrayList;
import java.util.List;
import java.util.regex.PatternSyntaxException;
import storage.*;

public class AddCommand {
    public static void run(String file) throws Exception {
        if (file.equals(".")) {
            Files.writeString(Paths.get(".gitkev/index"), "",
                    StandardOpenOption.CREATE, StandardOpenOption.TRUNCATE_EXISTING);
            addAll();
        } else {
            addFile(file);
        }
    }

    private static void addAll() throws Exception {
        Path root = Paths.get(".").toRealPath();
        List<PathMatcher> ignoreMatchers = loadGitignore(root);

        Files.walkFileTree(root, new SimpleFileVisitor<Path>() {
            @Override
            public FileVisitResult preVisitDirectory(Path dir, BasicFileAttributes attrs) {
                String name = dir.getFileName().toString();
                if (name.equals(".gitkev")) return FileVisitResult.SKIP_SUBTREE;
                

                // Get path relative to root for matching
                Path relative = root.relativize(dir);
                if (isIgnored(relative, ignoreMatchers)) {
                    System.out.println("Ignored (dir): " + relative);
                    return FileVisitResult.SKIP_SUBTREE;
                }
                return FileVisitResult.CONTINUE;
            }

            @Override
            public FileVisitResult visitFile(Path file, BasicFileAttributes attrs) throws IOException {
                if (file.getFileName().toString().endsWith(".class")) {
                    System.out.println("Skipped (class file): " + file);
                    return FileVisitResult.CONTINUE;
                }


                Path relative = root.relativize(file);
                if (isIgnored(relative, ignoreMatchers)) {
                    System.out.println("Ignored: " + relative);
                    return FileVisitResult.CONTINUE;
                }

                try {
                    addFile(file.toAbsolutePath().toString());
                } catch (Exception e) {
                    System.err.println("Skipped: " + file + " (" + e.getMessage() + ")");
                }
                return FileVisitResult.CONTINUE;
            }

            @Override
            public FileVisitResult visitFileFailed(Path file, IOException exc) {
                System.err.println("Skipped (access denied): " + file);
                return FileVisitResult.CONTINUE;
            }
        });
    }

    private static List<PathMatcher> loadGitignore(Path root) throws IOException {
        List<PathMatcher> matchers = new ArrayList<>();
        Path gitignore = root.resolve(".gitignore");

        if (!Files.exists(gitignore)) return matchers;

        FileSystem fs = FileSystems.getDefault();
        for (String line : Files.readAllLines(gitignore)) {
            line = line.trim();
            // Skip empty lines and comments
            if (line.isEmpty() || line.startsWith("#")) continue;

            try {
                // Match both the pattern directly and inside any subdirectory
                String pattern = line;
                matchers.add(fs.getPathMatcher("glob:" + pattern));
                matchers.add(fs.getPathMatcher("glob:**/" + pattern));
            } catch (PatternSyntaxException e) {
                System.err.println("Invalid .gitignore pattern skipped: " + line);
            }
        }
        return matchers;
    }

    private static boolean isIgnored(Path relativePath, List<PathMatcher> matchers) {
        for (PathMatcher matcher : matchers) {
            if (matcher.matches(relativePath)) return true;
        }
        return false;
    }

    private static void addFile(String file) throws Exception {
        Path path = Paths.get(file);
        if (Files.isDirectory(path)) return;

        byte[] data = Files.readAllBytes(path);
        String hash = Hasher.sha1(data);
        ObjectStore.writeObject(hash, data);
        Files.writeString(Paths.get(".gitkev/index"), hash + " " + file + "\n",
                StandardOpenOption.CREATE, StandardOpenOption.APPEND);
        System.out.println("Added: " + file + " → " + hash);
    }
}